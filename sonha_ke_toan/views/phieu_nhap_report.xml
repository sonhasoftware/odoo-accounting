<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <template id="report_phieu_nhap_document">
        <t t-call="web.html_container">
            <t t-if="docs and docs.ids">
                <t t-foreach="docs" t-as="o">
                    <div class="page" style="font-size: 14px; color: #000;">
                        <h2 style="text-align:center; text-transform: uppercase; margin-bottom: 8px;">PHIẾU NHẬP KHO</h2>
                        <p style="text-align:center; margin-top: 0;">
                            Ngày <span t-esc="o.NGAY_CT or ''"/> - Số: <span t-esc="o.CHUNG_TU or ''"/>
                        </p>

                        <p><strong>Họ và tên người giao hàng:</strong> <span t-esc="o.ONG_BA or ''"/></p>
                        <p><strong>Nhập tại kho:</strong> <span t-esc="o.KHO.MA_TEN if o.KHO else ''"/></p>
                        <p><strong>Nội dung:</strong> <span t-esc="o.GHI_CHU or ''"/></p>

                        <table style="width:100%; border-collapse: collapse;" border="1" cellpadding="4">
                            <thead>
                                <tr>
                                    <th>STT</th>
                                    <th>Tên hàng hóa</th>
                                    <th>Mã vật tư</th>
                                    <th>Đơn vị</th>
                                    <th>Số lượng</th>
                                    <th>Đơn giá</th>
                                    <th>Thành tiền</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="o.ACC_SP_D" t-as="line">
                                    <tr>
                                        <td><span t-esc="line_index + 1"/></td>
                                        <td><span t-esc="line.HANG_HOA.MA_TEN if line.HANG_HOA else ''"/></td>
                                        <td><span t-esc="line.HANG_HOA.MA if line.HANG_HOA else ''"/></td>
                                        <td><span t-esc="line.HANG_HOA.DVT if line.HANG_HOA else ''"/></td>
                                        <td style="text-align:right;"><span t-esc="line.SO_LUONG or 0"/></td>
                                        <td style="text-align:right;"><span t-esc="line.DON_GIA or 0"/></td>
                                        <td style="text-align:right;"><span t-esc="line.PS_NO1 or 0"/></td>
                                    </tr>
                                </t>
                            </tbody>
                        </table>
                    </div>
                </t>
            </t>
            <t t-else="">
                <div class="page" style="color:#000;">
                    <p>Không có dữ liệu để in. Vui lòng lưu chứng từ trước khi bấm In.</p>
                </div>
            </t>
        </t>
    </template>

    <record id="action_report_phieu_nhap" model="ir.actions.report">
        <field name="name">Phiếu nhập kho</field>
        <field name="model">nl.acc.ap.h</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">sonha_ke_toan.report_phieu_nhap_document</field>
        <field name="report_file">sonha_ke_toan.report_phieu_nhap_document</field>
        <field name="print_report_name">'Phieu_nhap_%s' % (object.CHUNG_TU or '')</field>
        <field name="binding_model_id" ref="model_nl_acc_ap_h"/>
        <field name="binding_type">report</field>
        <field name="multi">False</field>
    </record>

