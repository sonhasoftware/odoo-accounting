<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="sonha_accounting_log_tree_view" model="ir.ui.view">
        <field name="name">sonha.accounting.log.tree</field>
        <field name="model">sonha.accounting.log</field>
        <field name="arch" type="xml">
            <tree string="Nhật ký tạo sửa xóa" create="0" edit="0" delete="0">
                <field name="action_datetime"/>
                <field name="user_id"/>
                <field name="action"/>
                <field name="model_name"/>
                <field name="table_name"/>
                <field name="record_id"/>
                <field name="record_display_name"/>
                <field name="changed_fields"/>
                <field name="old_value_summary"/>
                <field name="new_value_summary"/>
            </tree>
        </field>
    </record>

    <record id="sonha_accounting_log_form_view" model="ir.ui.view">
        <field name="name">sonha.accounting.log.form</field>
        <field name="model">sonha.accounting.log</field>
        <field name="arch" type="xml">
            <form string="Nhật ký tạo sửa xóa" create="0" edit="0" delete="0">
                <sheet>
                    <group>
                        <group>
                            <field name="action_datetime"/>
                            <field name="user_id"/>
                            <field name="action"/>
                        </group>
                        <group>
                            <field name="model_name"/>
                            <field name="table_name"/>
                            <field name="record_id"/>
                            <field name="record_display_name"/>
                        </group>
                    </group>
                    <group string="Tóm tắt thay đổi">
                        <field name="changed_fields" placeholder="Các field được sửa"/>
                        <field name="old_value_summary" placeholder="Giá trị cũ theo từng field"/>
                        <field name="new_value_summary" placeholder="Giá trị mới theo từng field"/>
                    </group>
                    <notebook>
                        <page string="Chi tiết thay đổi">
                            <field name="line_ids" nolabel="1">
                                <tree create="0" edit="0" delete="0">
                                    <field name="field_label"/>
                                    <field name="field_name"/>
                                    <field name="old_value"/>
                                    <field name="new_value"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Dữ liệu cũ (JSON)">
                            <field name="old_values" nolabel="1"/>
                        </page>
                        <page string="Dữ liệu mới (JSON)">
                            <field name="new_values" nolabel="1"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="sonha_accounting_log_search_view" model="ir.ui.view">
        <field name="name">sonha.accounting.log.search</field>
        <field name="model">sonha.accounting.log</field>
        <field name="arch" type="xml">
            <search string="Tìm nhật ký">
                <field name="user_id"/>
                <field name="action"/>
                <field name="model_name"/>
                <field name="table_name"/>
                <field name="record_id"/>
                <field name="changed_fields"/>
                <filter string="Tạo" name="action_create" domain="[('action', '=', 'create')]"/>
                <filter string="Sửa" name="action_write" domain="[('action', '=', 'write')]"/>
                <filter string="Xóa" name="action_unlink" domain="[('action', '=', 'unlink')]"/>
                <group expand="0" string="Nhóm theo">
                    <filter string="Người dùng" name="group_user" context="{'group_by': 'user_id'}"/>
                    <filter string="Hành động" name="group_action" context="{'group_by': 'action'}"/>
                    <filter string="Bảng" name="group_table" context="{'group_by': 'table_name'}"/>
                    <filter string="Ngày" name="group_day" context="{'group_by': 'action_datetime:day'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="sonha_accounting_log_action" model="ir.actions.act_window">
        <field name="name">Nhật ký tạo sửa xóa</field>
        <field name="res_model">sonha.accounting.log</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="sonha_accounting_log_search_view"/>
        <field name="context">{'create': False, 'edit': False, 'delete': False}</field>
    </record>
</odoo>
