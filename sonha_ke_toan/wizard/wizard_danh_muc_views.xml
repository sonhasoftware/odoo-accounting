<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_wizard_danh_muc_form" model="ir.ui.view">
        <field name="name">wizard.danh.muc.form</field>
        <field name="model">wizard.danh.muc</field>
        <field name="arch" type="xml">
            <form string="Chọn phiếu in">
                <sheet>
                    <field name="phieu_in"/>
                </sheet>
                <footer>
                    <button string="In" type="object" name="action_print" class="oe_highlight"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="wizard_danh_muc_action" model="ir.actions.act_window">
        <field name="name">Chọn phiếu in</field>
        <field name="res_model">wizard.danh.muc</field>
        <field name="view_mode">form</field>
    </record>

</odoo>