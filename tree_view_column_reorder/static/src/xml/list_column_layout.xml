<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="tree_view_column_reorder.ListRenderer" t-inherit="web.ListRenderer" t-inherit-mode="extension">
        <xpath expr="//Dropdown[@t-if='displayOptionalFields']" position="inside">
            <div t-if="this._canCustomizeColumns()" role="separator" class="dropdown-divider"/>
            <DropdownItem t-if="this._canCustomizeColumns()" onSelected="() => this.resetColumnLayout()">
                <i class="fa fa-undo me-2"/>
                Reset column layout
            </DropdownItem>
        </xpath>
    </t>
</templates>
