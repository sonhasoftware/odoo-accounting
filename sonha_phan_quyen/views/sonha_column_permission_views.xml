<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_sonha_column_permission_tree" model="ir.ui.view">
        <field name="name">sonha.column.permission.tree</field>
        <field name="model">sonha.column.permission</field>
        <field name="arch" type="xml">
            <tree string="Phân quyền ẩn/hiện cột" editable="bottom">
                <field name="user_id"/>
                <field name="model_id"/>
                <field name="field_id" domain="[('model_id', '=', model_id)]"/>
                <field name="is_visible"/>
                <field name="active"/>
            </tree>
        </field>
    </record>

    <record id="view_sonha_column_permission_form" model="ir.ui.view">
        <field name="name">sonha.column.permission.form</field>
        <field name="model">sonha.column.permission</field>
        <field name="arch" type="xml">
            <form string="Phân quyền ẩn/hiện cột">
                <sheet>
                    <group>
                        <field name="user_id"/>
                        <field name="model_id"/>
                        <field name="field_id" domain="[('model_id', '=', model_id)]"/>
                    </group>
                    <group>
                        <field name="is_visible"/>
                        <field name="active"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_sonha_column_permission_search" model="ir.ui.view">
        <field name="name">sonha.column.permission.search</field>
        <field name="model">sonha.column.permission</field>
        <field name="arch" type="xml">
            <search string="Tìm phân quyền cột">
                <field name="user_id"/>
                <field name="model_id"/>
                <field name="field_name"/>
                <filter name="filter_hidden" string="Đang ẩn cột" domain="[('is_visible', '=', False)]"/>
            </search>
        </field>
    </record>

    <record id="action_sonha_column_permission" model="ir.actions.act_window">
        <field name="name">Phân quyền ẩn/hiện cột</field>
        <field name="res_model">sonha.column.permission</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_sonha_column_permission_search"/>
        <field name="context">{'active_test': False}</field>
    </record>

    <menuitem id="menu_sonha_column_permission"
              name="Ẩn/Hiện cột nhập liệu"
              parent="menu_sonha_phan_quyen_user"
              action="action_sonha_column_permission"
              sequence="3"/>
</odoo>
